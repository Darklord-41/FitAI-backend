# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/fitai
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fitai
MONGO_URI=mongodb://localhost:27017/fitai

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string

GMAIL_USER=your_email
GMAIL_CLIENT_ID=xyz
GMAIL_CLIENT_SECRET=xyz
GMAIL_REFRESH_TOKEN=xyz

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Set this to your frontend's URL for CORS
CLIENT_URL=http://localhost:5173
